NODE_ENV=development
PORT=3001
MONGODB_URI=mongodb://localhost:27017/flappybirds
REDIS_URL=redis://localhost:6379
# ─────────────────────────────────────────────────────────────
# Authentication toggle
# false (V1 default) — no JWT required; identity comes from client-supplied
#                      userId/username (handshake.auth on WS, headers on REST).
# true               — full JWT auth, account creation, ELO, game history.
#                      Set to true when you are ready to enable accounts.
# ─────────────────────────────────────────────────────────────
ENABLE_AUTH=false
JWT_SECRET=your-super-secret-min-32-chars-change-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:3001
RATE_LIMIT_WINDOW_MS=1
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
MAX_PLAYERS_PER_ROOM=50
BCRYPT_ROUNDS=12
DOMAIN=play.example.com
